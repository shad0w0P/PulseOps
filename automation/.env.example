# Automation Service Environment Variables
NODE_ENV=development
PORT=4001

# Backend Webhook
BACKEND_WEBHOOK_URL=http://localhost:4000/api/v1/webhook/events
WEBHOOK_SECRET=your-webhook-hmac-secret-here

# Backend Auth (for receiving commands from backend)
BACKEND_BEARER_TOKEN=your-automation-bearer-token-here

# OTP Timeout (5 minutes)
OTP_TIMEOUT_MS=300000

# CAPTCHA Timeout (3 minutes)
CAPTCHA_TIMEOUT_MS=180000

# Playwright
HEADLESS=false
SLOW_MO=0

# Income Tax Portal
PORTAL_URL=https://eportal.incometax.gov.in/iec/foservices/#/login
