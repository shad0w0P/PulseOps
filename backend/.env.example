# Backend Environment Variables
NODE_ENV=development
PORT=4000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/tax-automation

# Authentication
API_BEARER_TOKEN=your-api-bearer-token-here
WEBHOOK_SECRET=your-webhook-hmac-secret-here

# Automation Service
AUTOMATION_SERVICE_URL=http://localhost:4001
AUTOMATION_BEARER_TOKEN=your-automation-bearer-token-here

# Encryption (32-byte hex key for AES-256-GCM)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
